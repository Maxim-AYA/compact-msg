  "extract_filter": {
    "_comment": "Этап 2 (build_1_0.py): фильтр строк МСГ-листа gsheet для заполнения шаблона.",
    "x_startswith": "Бетонирование",
    "y_in": ["К1", "К2", "К3", "К4", "К5", "К6"],
    "match_rules": [
      { "pattern": "фундамент",          "target": "Цоколь.plate" },
      { "pattern": "стены подвала|стен подвала|D='Монолит ниже 0'\\s*AND\\s*E='Монолитные стены'", "target": "Цоколь.wall" },
      { "pattern": "перекрытие.*-0\\.100|-0\\.200|ПП0",                                          "target": "Цоколь.ceiling" },
      { "pattern": "стен(ы)?\\s*1[\\s-]?(ого|го)?\\s*этажа",                                     "target": "1 этаж.wall" },
      { "pattern": "ПП1(-1)?",                                                                    "target": "1 этаж.ceiling" },
      { "pattern": "стен(ы)?\\s*2[\\s-]?(ого|го)?\\s*этажа",                                     "target": "2 этаж.wall" },
      { "pattern": "ПП2(-1)?",                                                                    "target": "2 этаж.ceiling" },
      { "pattern": "стен(ы)?\\s*3[\\s-]?(ого|го)?\\s*этажа",                                     "target": "3 этаж.wall" },
      { "pattern": "ПП3(-1)?",                                                                    "target": "3 этаж.ceiling" },
      { "pattern": "стен(ы)?\\s*4[\\s-]?(ого|го)?\\s*этажа",                                     "target": "4 этаж.wall" },
      { "pattern": "плита покрытия.*\\+?13[\\.,]4",                                               "target": "4 этаж.ceiling" },
      { "pattern": "плита покрытия.*\\+?16[\\.,]7|стены.*\\+?16[\\.,]7|шахт",                    "target": "Мансарда.{plate|wall}" },
      { "pattern": "кровл",                                                                       "target": "Кровля.ceiling" },
      { "pattern": "лестниц|ЛК",                                                                  "target": "stair" },
      { "pattern": "рамп|ПР\\d-",                                                                  "target": "ramp" }
    ],
    "_note": "match_rules — черновой набросок для этапа 2. Уточнить и протестировать на реальном CSV-экспорте gsheet."
  }
}
